Description: Handle missing .git directory for tarball builds
 The GetGitCommitHash.cmake script fails fatally when building from a
 tarball without a .git directory. Add a guard to return gracefully.
Author: Aaron Yourk <ayourk@gmail.com>
Forwarded: not-needed
---
--- a/cmake/GetGitCommitHash.cmake
+++ b/cmake/GetGitCommitHash.cmake
@@ -3,6 +3,12 @@
     get_filename_component(GIT_ROOT ${GIT_DESCRIBE_CMAKE_DIR} PATH)
     set(GIT_DIR "${GIT_ROOT}/.git")
 
+    if(NOT EXISTS ${GIT_DIR})
+        message(WARNING "No .git directory found, cannot determine git commit hash")
+        set(GIT_COMMIT_HASH "unknown" PARENT_SCOPE)
+        return()
+    endif()
+
     if(EXISTS ${GIT_DIR} AND NOT IS_DIRECTORY ${GIT_DIR})
         # In case we are included as a git submodule.
         file(READ ${GIT_DIR} GIT_SUB_DIR)
